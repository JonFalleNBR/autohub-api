# ===========================================
# Configurações do Banco de Dados PostgreSQL
# ===========================================
POSTGRES_DB=autohub
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433

# ===========================================
# Configurações do pgAdmin
# ===========================================
PGADMIN_EMAIL=admin@autohub.com
PGADMIN_PASSWORD=changeme

# ===========================================
# URL de conexão JDBC (usada pela aplicação Spring)
# ===========================================
DB_URL=jdbc:postgresql://localhost:5433/autohub
